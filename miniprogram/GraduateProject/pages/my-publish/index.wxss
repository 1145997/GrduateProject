.info-card {
  display: flex;
  flex-direction: column;
}

.info-main {
  padding-bottom: 20rpx;
}

.title {
  font-size: 32rpx;
  font-weight: 700;
  color: #222;
  margin-bottom: 16rpx;
}

.meta-row {
  margin-bottom: 16rpx;
}

.desc {
  font-size: 26rpx;
  color: #555;
  margin-bottom: 10rpx;
}

.time {
  margin-top: 10rpx;
  font-size: 24rpx;
}

.op-row {
  display: flex;
  gap: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f2f2f2;
}

.mini-btn {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 26rpx;
  background: #f3f4f6;
  color: #333;
  border-radius: 12rpx;
}

.mini-btn.danger {
  background: #fee2e2;
  color: #dc2626;
}

.empty,
.load-text {
  text-align: center;
  padding: 40rpx 0;
  color: #999;
}