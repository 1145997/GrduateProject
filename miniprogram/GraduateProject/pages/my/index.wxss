.user-card {
  text-align: center;
  padding: 40rpx 24rpx;
}

.nickname {
  font-size: 36rpx;
  font-weight: 700;
  color: #222;
  margin-bottom: 14rpx;
}

.openid {
  font-size: 24rpx;
  color: #999;
  word-break: break-all;
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 88rpx;
  font-size: 30rpx;
  color: #333;
}

.arrow {
  color: #999;
}